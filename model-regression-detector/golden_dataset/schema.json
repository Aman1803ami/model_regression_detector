{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Golden Dataset",
  "description": "Schema for the golden evaluation dataset used by the Model Regression Detection System",
  "type": "object",
  "required": ["version", "created_at", "test_cases"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Dataset version identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of dataset creation"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this dataset version"
    },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "input_email", "expected_category", "expected_summary"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TC-[0-9]{3}$",
            "description": "Stable test case identifier (e.g., TC-001)"
          },
          "input_email": {
            "type": "string",
            "minLength": 10,
            "description": "The customer email text to classify"
          },
          "expected_category": {
            "type": "string",
            "enum": ["billing", "technical", "account", "general"],
            "description": "Correct classification category"
          },
          "expected_summary": {
            "type": "string",
            "description": "Ideal one-sentence summary of the email"
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"],
            "default": "medium",
            "description": "Expected difficulty for the classifier"
          },
          "notes": {
            "type": "string",
            "default": "",
            "description": "Why this test case exists or what edge case it covers"
          }
        }
      }
    }
  }
}
